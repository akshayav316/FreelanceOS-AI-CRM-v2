      "parameters": {
        "content": "📩 Workflow Purpose\n\n• Detect new Gmail inquiries\n• Prevent duplicate CRM entries\n• Analyze lead quality with AI\n• Schedule follow-ups\n• Generate reply drafts\n• Notify via Telegram",
        "height": 224,
        "width": 368
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -32,
